---
/**
 * About Page (French)
 *
 * Profile photo with minimalist design.
 * Content is loaded from a single bilingual file: src/content/about/about.md
 */
import Base from '@layouts/Base.astro';
import { getCollection } from 'astro:content';
import { getLocaleFromUrl, localized, t } from '@utils/i18n';
import OptimizedImage from '@components/OptimizedImage.astro';

const locale = getLocaleFromUrl(Astro.url);

const aboutEntries = await getCollection('about');
const about = aboutEntries.find(entry => entry.id === 'about.md') || aboutEntries[0];

if (!about) {
  throw new Error('No about content found. Create src/content/about/about.md');
}

const { profileImage } = about.data;
---

<Base title={t('nav.about', locale)}>
  <section class="about container">
    {profileImage && (
      <div class="about__image-wrap">
        <OptimizedImage
          src={profileImage.src}
          alt={localized(profileImage.alt, locale)}
          class="about__image"
          loading="eager"
          sizes="280px"
        />
      </div>
    )}
  </section>
</Base>

<style>
  .about {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - var(--header-height));
    padding: var(--space-4xl) 0;
  }

  .about__image-wrap {
    display: flex;
    justify-content: center;
  }

  .about__image-wrap :global(picture) {
    display: block;
  }

  .about__image-wrap :global(.about__image) {
    width: 240px;
    height: 240px;
    object-fit: cover;
    border-radius: 50%;
    border: 1px solid var(--color-border-subtle);
    box-shadow:
      0 4px 24px rgba(0, 0, 0, 0.3),
      0 0 0 1px rgba(255, 255, 255, 0.05);
  }

  @media (min-width: 768px) {
    .about__image-wrap :global(.about__image) {
      width: 280px;
      height: 280px;
    }
  }
</style>
