---
/**
 * Individual Post Page (EN)
 *
 * Dynamic route: /posts/[slug]
 * Thin wrapper — all rendering handled by PostPage component.
 */
import PostPage from '@components/PostPage.astro';
import { getCollection } from 'astro:content';
import { extractColorMetadata } from '@utils/extractColors';

export async function getStaticPaths() {
  const posts = await getCollection('posts');

  const postsWithColors = await Promise.all(
    posts.map(async (post) => {
      const imagePath = post.data.coverImage.src;
      const colorMeta = await extractColorMetadata(imagePath);

      if (colorMeta.colorFamily === 'neutral') {
        return {
          ...post,
          data: {
            ...post.data,
            glowColor: { r: 90, g: 90, b: 90, hex: '#5A5A5A' },
          },
        };
      }

      if (post.data.glowColor) return post;

      return {
        ...post,
        data: {
          ...post.data,
          glowColor: colorMeta,
        },
      };
    })
  );

  return postsWithColors.map(post => ({
    params: { slug: post.slug || post.id.replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
---

<PostPage post={post} />
