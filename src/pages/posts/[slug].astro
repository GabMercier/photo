---
/**
 * Individual Post Page (EN)
 *
 * Dynamic route: /posts/[slug]
 * Thin wrapper — all rendering handled by PostPage component.
 */
import PostPage from '@components/PostPage.astro';
import { getCollection } from 'astro:content';
import { extractColorMetadata } from '@utils/extractColors';

export async function getStaticPaths() {
  const posts = await getCollection('posts');

  // glowColor populated by prebuild script; fallback extraction for dev
  const postsWithColors = await Promise.all(
    posts.map(async (post) => {
      if (post.data.glowColor) return post;

      const colorMeta = await extractColorMetadata(post.data.coverImage.src);
      return {
        ...post,
        data: {
          ...post.data,
          glowColor: colorMeta.colorFamily === 'neutral' ? '#5A5A5A' : colorMeta.hex,
        },
      };
    })
  );

  return postsWithColors.map(post => ({
    params: { slug: post.slug || post.id.replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
---

<PostPage post={post} />
