---
/**
 * Header Component
 * 
 * Minimal, fixed navigation bar.
 * - Logo/site name on the left
 * - Nav links + language switcher + theme switcher on the right
 * - Hamburger menu on mobile
 * - Hides on scroll down, shows on scroll up (via JS)
 */
import { getLocaleFromUrl, t, localePath, alternateLocalePath } from '@utils/i18n';

const locale = getLocaleFromUrl(Astro.url);
const currentPath = Astro.url.pathname;

// Navigation links
const navLinks = [
  { key: 'nav.feed', path: '/feed' },
  { key: 'nav.gallery', path: '/gallery' },
  { key: 'nav.about', path: '/about' },
];

/**
 * Check if a nav link is the current page.
 * Handles both /feed and /fr/feed cases.
 */
function isActive(linkPath: string): boolean {
  const localized = localePath(linkPath, locale);
  return currentPath === localized || currentPath === localized + '/';
}
---

<header class="header" id="site-header">
  <div class="header__inner container">
    <!-- Logo / Site name - collapses to dot on scroll -->
    <a href={localePath('/', locale)} class="header__logo" aria-label="Home">
      <span class="logo__dot" aria-hidden="true"></span>
    </a>

    <!-- Desktop navigation -->
    <nav class="header__nav" aria-label="Main navigation">
      {navLinks.map(link => (
        <a
          href={localePath(link.path, locale)}
          class:list={['header__link', { 'header__link--active': isActive(link.path) }]}
        >
          {t(link.key, locale)}
        </a>
      ))}

      <!-- Language switcher -->
      <a href={alternateLocalePath(Astro.url)} class="header__lang" aria-label="Switch language">
        {t('lang.switch', locale)}
      </a>
    </nav>

    <!-- Mobile hamburger -->
    <button
      class="header__hamburger"
      id="mobile-menu-toggle"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <span class="header__hamburger-line"></span>
      <span class="header__hamburger-line"></span>
    </button>
  </div>

  <!-- Glass edge fade — dissolves content at the header boundary -->
  <div class="header__edge-fade" aria-hidden="true"></div>

  <!-- Mobile menu overlay (full-screen) -->
  <div class="header__mobile-menu" id="mobile-menu" inert>
    <nav class="header__mobile-nav">
      {navLinks.map((link, index) => (
        <a
          href={localePath(link.path, locale)}
          class:list={['header__mobile-link', { 'header__mobile-link--active': isActive(link.path) }]}
          style={`--link-index: ${index}`}
        >
          {t(link.key, locale)}
        </a>
      ))}
      <div class="header__mobile-controls" style="--link-index: 3">
        <a href={alternateLocalePath(Astro.url)} class="header__mobile-lang">
          {t('lang.switch', locale)}
        </a>
      </div>
    </nav>
  </div>
</header>

<!-- Client-side scripts for mobile menu and scroll behavior -->
<script>
  /**
   * Mobile menu toggle
   */
  function initMobileMenu() {
    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const header = document.getElementById('site-header');
    if (!toggle || !menu || !header) return;

    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!isOpen));
      menu.inert = isOpen; // inert when closed
      menu.classList.toggle('header__mobile-menu--open');
      toggle.classList.toggle('header__hamburger--open');
      header.classList.toggle('header--menu-open');

      // Prevent body scroll when menu is open
      document.body.style.overflow = isOpen ? '' : 'hidden';
    });

    // Close menu on link click
    menu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        toggle.setAttribute('aria-expanded', 'false');
        menu.inert = true;
        menu.classList.remove('header__mobile-menu--open');
        toggle.classList.remove('header__hamburger--open');
        header.classList.remove('header--menu-open');
        document.body.style.overflow = '';
      });
    });
  }

  /**
   * Logo scroll behavior - collapse to dot on scroll or inactivity
   * Expands again on page load/navigation only
   */
  function initScrollBehavior() {
    const header = document.getElementById('site-header');
    if (!header) return;

    const SCROLL_THRESHOLD = 50;
    const INACTIVITY_DELAY = 3000; // 3 seconds

    let inactivityTimeout: ReturnType<typeof setTimeout> | null = null;
    let inactivityCollapsed = false; // Track if collapsed by inactivity

    function collapse() {
      header.classList.add('header--scrolled');
    }

    function expand() {
      // Don't expand if already collapsed by inactivity
      if (inactivityCollapsed) return;
      header.classList.remove('header--scrolled');
    }

    function updateHeaderState() {
      if (window.scrollY > SCROLL_THRESHOLD) {
        collapse();
      } else {
        expand();
      }

      // Scroll-reactive glass: ramp blur 12→24 and bg alpha 0.04→0.08 over first 300px
      const scrollProgress = Math.min(window.scrollY / 300, 1);
      const blur = 12 + scrollProgress * 12;
      const bgAlpha = 0.04 + scrollProgress * 0.04;
      const refractionOpacity = 0.6 + scrollProgress * 0.4;
      header.style.setProperty('--header-blur', blur.toString());
      header.style.setProperty('--header-bg-alpha', bgAlpha.toFixed(3));
      header.style.setProperty('--refraction-opacity', refractionOpacity.toFixed(2));
    }

    // Initial check
    updateHeaderState();

    // Start inactivity timer (only runs once per page load)
    inactivityTimeout = setTimeout(() => {
      // Only collapse if not already scrolled down
      if (window.scrollY <= SCROLL_THRESHOLD) {
        inactivityCollapsed = true;
        collapse();
      }
    }, INACTIVITY_DELAY);

    // Listen for scroll - scrolling up at top expands, scrolling down collapses
    window.addEventListener('scroll', updateHeaderState, { passive: true });

    // Cleanup on navigation
    document.addEventListener('astro:before-swap', () => {
      if (inactivityTimeout) clearTimeout(inactivityTimeout);
    }, { once: true });
  }

  // Initialize on first load
  initMobileMenu();
  initScrollBehavior();

  // Re-initialize after Astro View Transitions swap
  document.addEventListener('astro:after-swap', () => {
    initMobileMenu();
    initScrollBehavior();
  });
</script>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--header-height);
    z-index: var(--z-header);
    overflow: visible;

    /* Subtle bottom edge highlight */
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);

    /* Inset illumination — top highlight, bottom fade */
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.1),
      inset 0 -1px 0 rgba(255, 255, 255, 0.03),
      0 2px 16px rgba(0, 0, 0, 0.15);

    /* Scroll-reactive blur: JS sets --header-blur (12-24) and --header-bg-alpha (0.04-0.08) */
    --header-blur: 12;
    --header-bg-alpha: 0.04;
    background: rgba(255, 255, 255, var(--header-bg-alpha));
    backdrop-filter: blur(calc(var(--header-blur) * 1px)) saturate(180%);
    -webkit-backdrop-filter: blur(calc(var(--header-blur) * 1px)) saturate(180%);

    transition: box-shadow var(--transition-base);
  }

  /* Shimmer highlight — slow diagonal light sweep */
  .header::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      165deg,
      rgba(255, 255, 255, 0.06) 0%,
      transparent 30%,
      transparent 70%,
      rgba(255, 255, 255, 0.03) 100%
    );
    pointer-events: none;
    z-index: 0;
  }

  @media (prefers-reduced-motion: no-preference) {
    .header::before {
      animation: header-shimmer 8s ease-in-out infinite;
    }
  }

  @keyframes header-shimmer {
    0%, 100% {
      opacity: 1;
      background-position: 0% 0%;
    }
    50% {
      opacity: 0.5;
      background-position: 100% 100%;
    }
  }

  /* Prismatic edge refraction — rainbow gradient along bottom border */
  .header::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1px;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      oklch(0.67 0.18 25 / 0.2) 10%,
      oklch(0.67 0.16 60 / 0.25) 20%,
      oklch(0.67 0.15 100 / 0.2) 30%,
      oklch(0.62 0.14 145 / 0.2) 40%,
      oklch(0.67 0.15 240 / 0.25) 55%,
      oklch(0.67 0.14 300 / 0.2) 70%,
      oklch(0.67 0.14 340 / 0.2) 85%,
      transparent 100%
    );
    pointer-events: none;
    z-index: 1;
    opacity: var(--refraction-opacity, 0.6);
    transition: opacity 0.3s ease;
  }

  /* Glass edge fade — content dissolves at the header boundary */
  .header__edge-fade {
    position: absolute;
    left: 0;
    right: 0;
    top: 100%;
    height: 16px;
    pointer-events: none;
    z-index: 0;
    backdrop-filter: blur(calc(var(--header-blur) * 0.6px)) saturate(140%);
    -webkit-backdrop-filter: blur(calc(var(--header-blur) * 0.6px)) saturate(140%);
    -webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,0.5), transparent);
    mask-image: linear-gradient(to bottom, rgba(0,0,0,0.5), transparent);
  }

  /* When mobile menu is open, solid background */
  .header--menu-open {
    background-color: var(--color-bg);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    box-shadow: none;
    border-bottom-color: transparent;
  }

  .header--menu-open::before,
  .header--menu-open::after,
  .header--menu-open .header__edge-fade {
    display: none;
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    overflow: visible;
    position: relative;
    z-index: 2; /* Above mobile menu overlay */
    max-width: none;
    padding-inline: var(--space-md);
  }

  /* Logo - glass dot only */
  .header__logo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    padding: var(--space-xs);
    overflow: visible;
  }

  /* Glass dot — the sole logo mark
   * Chroma scales with --chroma-raw (0 for B&W images) */
  .logo__dot {
    display: block;
    width: 28px;
    height: 28px;
    flex-shrink: 0;
    position: relative;
    border-radius: 50%;
    overflow: hidden;

    /* Hollow glass - subtle translucent center */
    background: radial-gradient(
      circle at center,
      oklch(0.81 calc(var(--chroma-raw, 0.02) * 1) var(--color-accent-hue) / 0.03) 0%,
      oklch(0.75 calc(var(--chroma-raw, 0.02) * 1.33) var(--color-accent-hue) / 0.08) 70%,
      oklch(0.69 calc(var(--chroma-raw, 0.02) * 1.5) var(--color-accent-hue) / 0.12) 100%
    );

    /* Crisp glass rim */
    border: 1.5px solid oklch(0.78 calc(var(--chroma-raw, 0.02) * 1) var(--color-accent-hue) / 0.8);

    /* Subtle glow */
    box-shadow:
      inset 0 0 4px oklch(1.0 calc(var(--chroma-raw, 0.02) * 0.83) var(--color-accent-hue) / 0.1),
      0 0 6px oklch(0.77 calc(var(--chroma-raw, 0.02) * 1.5) var(--color-accent-hue) / 0.15);

    transition:
      box-shadow var(--transition-base),
      border-color var(--transition-base);
  }

  /* Highlight arc — rotates slowly like light catching glass */
  .logo__dot::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: 50%;
    background: linear-gradient(
      160deg,
      oklch(1.0 calc(var(--chroma-raw, 0.02) * 1) var(--color-accent-hue) / 0.35) 0%,
      oklch(1.0 calc(var(--chroma-raw, 0.02) * 0.83) var(--color-accent-hue) / 0.12) 20%,
      transparent 45%
    );
    pointer-events: none;
  }

  /* Lens flare sweep — periodic bright streak across the glass */
  .logo__dot::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: linear-gradient(
      105deg,
      transparent 0%,
      transparent 38%,
      oklch(0.93 calc(var(--chroma-raw, 0.02) * 1) var(--color-accent-hue) / 0.35) 46%,
      oklch(1.0 calc(var(--chroma-raw, 0.02) * 0.5) var(--color-accent-hue) / 0.55) 50%,
      oklch(0.93 calc(var(--chroma-raw, 0.02) * 1) var(--color-accent-hue) / 0.35) 54%,
      transparent 62%,
      transparent 100%
    );
    translate: -120% 0;
    opacity: 0;
    pointer-events: none;
  }

  /* Hover — brighter rim + glow */
  .header__logo:hover .logo__dot {
    border-color: oklch(0.85 calc(var(--chroma-raw, 0.02) * 1.25) var(--color-accent-hue) / 0.9);
    box-shadow:
      inset 0 0 5px oklch(1.0 calc(var(--chroma-raw, 0.02) * 1) var(--color-accent-hue) / 0.15),
      0 0 10px oklch(0.77 calc(var(--chroma-raw, 0.02) * 1.83) var(--color-accent-hue) / 0.25);
  }

  /* Animations — flare sweep + breathing glow */
  @media (prefers-reduced-motion: no-preference) {
    .logo__dot {
      animation: dot-breathe 6s ease-in-out infinite;
    }

    .logo__dot::after {
      animation: flare-sweep 8s ease-in-out infinite;
      animation-delay: 3s;
    }

    .header__logo:hover .logo__dot {
      animation: none;
    }

    .header__logo:hover .logo__dot::after {
      animation: none;
      opacity: 0;
    }
  }

  /* Gentle breathing glow */
  @keyframes dot-breathe {
    0%, 100% {
      box-shadow:
        inset 0 0 4px oklch(1.0 calc(var(--chroma-raw, 0.02) * 0.83) var(--color-accent-hue) / 0.1),
        0 0 6px oklch(0.77 calc(var(--chroma-raw, 0.02) * 1.5) var(--color-accent-hue) / 0.15);
    }
    50% {
      box-shadow:
        inset 0 0 5px oklch(1.0 calc(var(--chroma-raw, 0.02) * 1) var(--color-accent-hue) / 0.14),
        0 0 8px oklch(0.77 calc(var(--chroma-raw, 0.02) * 1.67) var(--color-accent-hue) / 0.22);
    }
  }

  /* Lens flare — bright streak sweeps across every 8s */
  @keyframes flare-sweep {
    0%, 82% {
      translate: -120% 0;
      opacity: 0;
    }
    86% {
      opacity: 0.7;
    }
    92% {
      translate: 120% 0;
      opacity: 0.7;
    }
    96%, 100% {
      translate: 120% 0;
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .logo__dot,
    .logo__dot::after {
      animation: none !important;
    }
  }

  /* Desktop nav */
  .header__nav {
    display: none;
    align-items: center;
    gap: var(--space-xl);
  }

  @media (min-width: 640px) {
    .header__nav {
      display: flex;
    }
    .header__hamburger {
      display: none !important;
    }
  }

  .header__link {
    font-size: var(--text-sm);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    padding-block: var(--space-xs);
    position: relative;

    /* Glass text effect - chroma scales with --chroma-raw */
    color: transparent;
    -webkit-text-fill-color: transparent;
    background: linear-gradient(
      165deg,
      oklch(0.81 calc(var(--chroma-raw, 0.02) * 0.67) var(--color-accent-hue) / 0.06) 0%,
      oklch(0.77 calc(var(--chroma-raw, 0.02) * 0.83) var(--color-accent-hue) / 0.02) 50%,
      oklch(0.81 calc(var(--chroma-raw, 0.02) * 0.67) var(--color-accent-hue) / 0.06) 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-stroke: 0.8px oklch(0.75 calc(var(--chroma-raw, 0.02) * 0.83) var(--color-accent-hue) / 0.75);
    text-shadow:
      0 0 5px oklch(0.77 calc(var(--chroma-raw, 0.02) * 1.25) var(--color-accent-hue) / 0.12),
      -0.3px 0 0 oklch(0.69 calc(var(--chroma-raw, 0.02) * 3.75) 25 / 0.12),
      0.3px 0 0 oklch(0.69 calc(var(--chroma-raw, 0.02) * 3.75) 195 / 0.12);

    transition: all var(--transition-fast);
  }

  .header__link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      oklch(0.67 calc(var(--chroma-raw, 0.02) * 4.2) 25 / 0.3),
      oklch(0.81 calc(var(--chroma-raw, 0.02) * 1.25) var(--color-accent-hue) / 0.6),
      oklch(0.67 calc(var(--chroma-raw, 0.02) * 4.2) 195 / 0.3)
    );
    transform: scaleX(0);
    transition: transform var(--transition-base);
  }

  .header__link:hover {
    -webkit-text-stroke: 0.8px oklch(0.83 calc(var(--chroma-raw, 0.02) * 1) var(--color-accent-hue) / 0.9);
    text-shadow:
      0 0 8px oklch(0.77 calc(var(--chroma-raw, 0.02) * 1.5) var(--color-accent-hue) / 0.2),
      -0.4px 0 0 oklch(0.69 calc(var(--chroma-raw, 0.02) * 4.2) 25 / 0.16),
      0.4px 0 0 oklch(0.69 calc(var(--chroma-raw, 0.02) * 4.2) 195 / 0.16);
  }

  .header__link:hover::after {
    transform: scaleX(1);
  }

  .header__link--active {
    -webkit-text-stroke: 0.8px oklch(0.85 calc(var(--chroma-raw, 0.02) * 1.25) var(--color-accent-hue) / 0.95);
    text-shadow:
      0 0 10px oklch(0.77 calc(var(--chroma-raw, 0.02) * 1.67) var(--color-accent-hue) / 0.25),
      -0.5px 0 0 oklch(0.69 calc(var(--chroma-raw, 0.02) * 4.6) 25 / 0.18),
      0.5px 0 0 oklch(0.69 calc(var(--chroma-raw, 0.02) * 4.6) 195 / 0.18);
  }

  .header__link--active::after {
    transform: scaleX(1);
  }

  /* Language switcher - chroma scales with --chroma-raw */
  .header__lang {
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--border-radius);

    /* Glass effect */
    color: transparent;
    -webkit-text-fill-color: transparent;
    background: linear-gradient(
      165deg,
      oklch(0.78 calc(var(--chroma-raw, 0.02) * 0.67) var(--color-accent-hue) / 0.04) 0%,
      oklch(0.75 calc(var(--chroma-raw, 0.02) * 0.83) var(--color-accent-hue) / 0.02) 50%,
      oklch(0.78 calc(var(--chroma-raw, 0.02) * 0.67) var(--color-accent-hue) / 0.04) 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-stroke: 0.6px oklch(0.72 calc(var(--chroma-raw, 0.02) * 0.83) var(--color-accent-hue) / 0.65);
    text-shadow:
      -0.3px 0 0 oklch(0.67 calc(var(--chroma-raw, 0.02) * 3.3) 25 / 0.1),
      0.3px 0 0 oklch(0.67 calc(var(--chroma-raw, 0.02) * 3.3) 195 / 0.1);

    border: 1px solid oklch(0.72 calc(var(--chroma-raw, 0.02) * 0.83) var(--color-accent-hue) / 0.35);
    transition: all var(--transition-fast);
  }

  .header__lang:hover {
    -webkit-text-stroke: 0.6px oklch(0.81 calc(var(--chroma-raw, 0.02) * 1) var(--color-accent-hue) / 0.85);
    border-color: oklch(0.78 calc(var(--chroma-raw, 0.02) * 1) var(--color-accent-hue) / 0.55);
    text-shadow:
      0 0 6px oklch(0.77 calc(var(--chroma-raw, 0.02) * 1.25) var(--color-accent-hue) / 0.15),
      -0.4px 0 0 oklch(0.67 calc(var(--chroma-raw, 0.02) * 3.75) 25 / 0.14),
      0.4px 0 0 oklch(0.67 calc(var(--chroma-raw, 0.02) * 3.75) 195 / 0.14);
  }

  /* Hamburger (mobile) */
  .header__hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 6px;
    width: 28px;
    height: 28px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .header__hamburger-line {
    display: block;
    width: 100%;
    height: 2px;
    border-radius: 1px;

    /* Glass effect on lines - chroma scales with --chroma-raw */
    background: linear-gradient(
      90deg,
      oklch(0.69 calc(var(--chroma-raw, 0.02) * 3.75) 25 / 0.25),
      oklch(0.78 calc(var(--chroma-raw, 0.02) * 1) var(--color-accent-hue) / 0.8),
      oklch(0.69 calc(var(--chroma-raw, 0.02) * 3.75) 195 / 0.25)
    );
    box-shadow:
      0 0 4px oklch(0.77 calc(var(--chroma-raw, 0.02) * 1.25) var(--color-accent-hue) / 0.15);

    transition: translate var(--transition-base), rotate var(--transition-base), opacity var(--transition-fast), background var(--transition-fast);
  }

  .header__hamburger:hover .header__hamburger-line {
    background: linear-gradient(
      90deg,
      oklch(0.69 calc(var(--chroma-raw, 0.02) * 4.2) 25 / 0.35),
      oklch(0.83 calc(var(--chroma-raw, 0.02) * 1.25) var(--color-accent-hue) / 0.9),
      oklch(0.69 calc(var(--chroma-raw, 0.02) * 4.2) 195 / 0.35)
    );
    box-shadow:
      0 0 6px oklch(0.77 calc(var(--chroma-raw, 0.02) * 1.5) var(--color-accent-hue) / 0.22);
  }

  .header__hamburger--open .header__hamburger-line:first-child {
    translate: 0 4px;
    rotate: 45deg;
  }

  .header__hamburger--open .header__hamburger-line:last-child {
    translate: 0 -4px;
    rotate: -45deg;
  }

  /* ================================== */
  /* Mobile menu overlay (full-screen) */
  /* ================================== */
  .header__mobile-menu {
    position: fixed;
    inset: 0;
    background-color: var(--color-bg);
    z-index: calc(var(--z-header) - 1);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition:
      opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1),
      visibility 0.4s;
  }

  .header__mobile-menu--open {
    opacity: 1;
    visibility: visible;
