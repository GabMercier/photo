---
/**
 * HomePage Component
 *
 * Shared homepage template used by both EN and FR routes.
 * Full-screen carousel showcasing selected photography posts.
 */
import Base from '@layouts/Base.astro';
import HomepageCarousel from '@components/HomepageCarousel.astro';
import HomepageHero from '@components/HomepageHero.astro';
import { getCollection } from 'astro:content';
import { getLocaleFromUrl, localized } from '@utils/i18n';
import { deriveAccentFromGlow, hexToRgb } from '@utils/extractColors';
import { getOgImageData } from '@utils/optimizedImage';

const locale = getLocaleFromUrl(Astro.url);

// Fetch posts marked for carousel (glowColor populated by prebuild script)
const carouselPosts = (await getCollection('posts', ({ data }) => {
  return data.homepageCarousel && !data.draft && !data.private;
})).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Find default post
const defaultPost = carouselPosts.find(p => p.data.homepageDefault);
const defaultSlug = defaultPost?.slug;

// Get initial accent from default post or first post
const initialPost = defaultPost || carouselPosts[0];
const initialGlow = initialPost?.data.glowColor
  ? hexToRgb(initialPost.data.glowColor)
  : { r: 58, g: 68, b: 71 };
const initialAccent = deriveAccentFromGlow(initialGlow.r, initialGlow.g, initialGlow.b);

// OG image: use featured post, fallback to carousel default, fallback to latest
const allPostsForOg = (await getCollection('posts', ({ data }) => !data.draft && !data.private))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const featuredPost = allPostsForOg.find(p => p.data.featured);
const ogPost = featuredPost || initialPost || allPostsForOg[0];

const ogData = ogPost ? await getOgImageData(ogPost.data.coverImage.src) : null;
const ogImageAlt = ogPost
  ? (localized(ogPost.data.coverImage.alt, locale) || localized(ogPost.data.title, locale) || 'Gabriel Mercier Photography')
  : 'Gabriel Mercier Photography';

// Structured data (Schema.org)
const siteUrl = import.meta.env.SITE || Astro.url.origin;
const homepageSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  mainEntity: {
    '@type': 'Person',
    name: 'Gabriel Mercier',
    url: siteUrl,
    jobTitle: 'Photographer',
    knowsAbout: ['Photography', 'Landscape Photography', 'Nature Photography'],
  },
};
---

<Base
  ogImage={ogData?.ogImage}
  ogImageAlt={ogImageAlt}
  ogImageWidth={ogData?.ogImageWidth}
  ogImageHeight={ogData?.ogImageHeight}
  accentHue={carouselPosts.length > 0 ? initialAccent.hue : undefined}
  accentChroma={carouselPosts.length > 0 ? initialAccent.chroma : undefined}
  accentLightness={carouselPosts.length > 0 ? initialAccent.lightness : undefined}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(homepageSchema)} />
  </Fragment>
  {carouselPosts.length > 0 ? (
    <HomepageCarousel
      carouselPosts={carouselPosts}
      defaultPostSlug={defaultSlug}
      locale={locale}
    />
  ) : (
    <HomepageHero />
  )}
</Base>
