{
  "name": "gmbpho-to",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "optimize-images": "tsx scripts/optimize-images.ts",
    "generate-depth-maps": "test -f scripts/.venv/bin/python && scripts/.venv/bin/python scripts/generate-depth-maps.py || echo 'Skipping depth maps (no Python venv)'",
    "extract-glow-colors": "tsx scripts/extract-glow-colors.ts",
    "extract-exif": "tsx scripts/extract-exif.ts",
    "prebuild": "npm run optimize-images && npm run extract-glow-colors && npm run extract-exif && npm run generate-depth-maps"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/rss": "^4.0.15",
    "@astrojs/sitemap": "^3.7.0",
    "astro": "^5.17.3",
    "marked": "^17.0.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.2",
    "exif-reader": "^2.0.3",
    "sharp": "^0.34.5",
    "tsx": "^4.7.0",
    "typescript": "^5.9.3"
  }
}
